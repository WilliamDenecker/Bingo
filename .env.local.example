# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-side only, never expose to browser
# Only needed if you add admin-level server operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
